---
import PageLayout from '~/layouts/PageLayout.astro';

const meta = {
  title: 'AIwind - AI Tools Hub',
  description: 'Explore the frontier of intelligence | 25+ Free AI Tools Navigation',
};
---

<PageLayout metadata={meta}>

  <!-- English Hero -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 bg-cyan-500/10 text-cyan-400 rounded-full px-4 py-1.5 text-sm font-medium mb-6">
        AI Empowers the Future
      </div>
      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">
        Explore the Frontier of Intelligence<br>
        Unlock Infinite AI Power
      </h1>
      <p class="text-xl text-muted max-w-2xl mx-auto mb-10">
        From intelligent conversation, image generation, video creation,<br>
        to content writing and frontier models — all-in-one AI platform
      </p>
      <div class="flex justify-center gap-4">
        <a href="/tools" class="bg-white text-black px-8 py-4 rounded-2xl font-semibold flex items-center gap-2 hover:bg-cyan-400 transition-colors">
          Explore AI Tools →
        </a>
        <a href="/blog" class="border border-white/30 px-8 py-4 rounded-2xl font-semibold hover:bg-white/10 transition-colors">
          Latest AI Insights
        </a>
      </div>
    </div>
  </div>

  <!-- English AI Tools Cards -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">Popular AI Tool Categories</h2>
      <p class="text-xl text-muted max-w-2xl mx-auto">One-stop exploration of the world's most powerful AI tools</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-cyan-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">💬</div>
        <h3 class="text-2xl font-semibold mb-3">Intelligent Chat</h3>
        <p class="text-zinc-400">ChatGPT, Claude, Gemini, Grok, DeepSeek</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-purple-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">🖼️</div>
        <h3 class="text-2xl font-semibold mb-3">Image Generation</h3>
        <p class="text-zinc-400">Midjourney, Flux, DALL·E, Stable Diffusion, Ideogram</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-pink-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">🎥</div>
        <h3 class="text-2xl font-semibold mb-3">Video & Music</h3>
        <p class="text-zinc-400">Sora, Runway, Kling, Suno, Udio, Luma</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-emerald-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">✍️</div>
        <h3 class="text-2xl font-semibold mb-3">Writing & Content</h3>
        <p class="text-zinc-400">Notion AI, Cursor, Perplexity, Jasper, Gamma</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-amber-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">💻</div>
        <h3 class="text-2xl font-semibold mb-3">Code & Data</h3>
        <p class="text-zinc-400">Cursor, Blackbox, GitHub Copilot, Poe</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-rose-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">🌐</div>
        <h3 class="text-2xl font-semibold mb-3">More Tools</h3>
        <p class="text-zinc-400">25+ free AI tools updated in real time</p>
      </div>
    </div>
  </div>

</PageLayout>
