        <h3 class="text-2xl font-semibold mb-2">Kling AI</h3>
        <p class="text-zinc-400">快手视频生成</p>
      </a>
      <a href="https://suno.com" target="_blank" class="block bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-emerald-400 transition-all group">
