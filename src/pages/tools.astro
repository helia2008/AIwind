---
import PageLayout from '~/layouts/PageLayout.astro';

const meta = {
  title: 'AI 工具大全',
  description: '25+ 免费 AI 工具实时导航 | ChatGPT / Midjourney / Claude / Sora 等一站式体验',
};
---

<PageLayout metadata={meta}>
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center mb-12">
      <h1 class="text-5xl font-bold tracking-tight mb-4">AI 工具大全</h1>
      <p class="text-xl text-muted">实时收录全球最热门 AI 工具，一键直达，持续更新</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- 这里放你想要的 25+ 工具卡片，我先给 8 个示例，你可以继续复制添加 -->
      <a href="https://chat.openai.com" target="_blank" class="block bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-cyan-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110">💬</div>
        <h3 class="text-2xl font-semibold mb-2">ChatGPT</h3>
        <p class="text-zinc-400">OpenAI 官方对话工具</p>
      </a>
      <!-- 继续添加其他工具卡片... -->
    </div>
  </div>
</PageLayout>
