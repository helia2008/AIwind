---
import PageLayout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';

const meta = {
  title: 'AI 工具大全',
  description: '25+ 免费 AI 工具实时导航 | ChatGPT / Midjourney / Claude / Sora 等一站式体验',
};
---

<PageLayout metadata={meta}>
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="text-center mb-12">
      <h1 class="text-5xl font-bold tracking-tight mb-4">AI 工具大全</h1>
      <p class="text-xl text-muted max-w-2xl mx-auto">实时收录全球最热门 AI 工具，一键直达，持续更新</p>
    </div>

    <Features
      title="25+ 热门 AI 工具"
      items={[
        { title: "ChatGPT", description: "OpenAI 官方对话", icon: "tabler:message-chatbot", href: "https://chat.openai.com" },
        { title: "Claude", description: "Anthropic 最强模型", icon: "tabler:message-chatbot", href: "https://claude.ai" },
        { title: "Gemini", description: "Google 最新大模型", icon: "tabler:message-chatbot", href: "https://gemini.google.com" },
        { title: "Grok", description: "xAI 幽默 AI", icon: "tabler:message-chatbot", href: "https://grok.x.ai" },
        { title: "Midjourney", description: "顶级图像生成", icon: "tabler:photo", href: "https://midjourney.com" },
        { title: "Flux", description: "最新开源图像模型", icon: "tabler:photo", href: "https://flux.ai" },
        { title: "Sora", description: "OpenAI 视频生成", icon: "tabler:video", href: "https://openai.com/sora" },
        { title: "Runway", description: "专业视频生成", icon: "tabler:video", href: "https://runwayml.com" },
        { title: "Cursor", description: "AI 代码编辑器", icon: "tabler:code", href: "https://cursor.com" },
        { title: "Perplexity", description: "AI 搜索引擎", icon: "tabler:search", href: "https://perplexity.ai" },
        // 你可以继续添加更多工具...
      ]}
    />
  </div>
</PageLayout>
