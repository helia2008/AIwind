---
import PageLayout from '~/layouts/PageLayout.astro';

const meta = {
  title: 'AIwind - AI 工具导航站',
  description: '探索智能边界 | 25+ 免费 AI 工具一站式导航',
};
---

<PageLayout metadata={meta}>

  <!-- AI 工具分类卡片（最终完美版） -->
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">热门 AI 工具分类</h2>
      <p class="text-xl text-muted max-w-2xl mx-auto">一站式探索全球最强 AI 工具，实时更新</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-cyan-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">💬</div>
        <h3 class="text-2xl font-semibold mb-3">智能对话</h3>
        <p class="text-zinc-400">ChatGPT、Claude、Gemini、Grok、DeepSeek</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-purple-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">🖼️</div>
        <h3 class="text-2xl font-semibold mb-3">图像生成</h3>
        <p class="text-zinc-400">Midjourney、Flux、DALL·E、Stable Diffusion、Ideogram</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-pink-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">🎥</div>
        <h3 class="text-2xl font-semibold mb-3">视频 & 音乐</h3>
        <p class="text-zinc-400">Sora、Runway、Kling、Suno、Udio、Luma</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-emerald-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">✍️</div>
        <h3 class="text-2xl font-semibold mb-3">写作 & 内容</h3>
        <p class="text-zinc-400">Notion AI、Cursor、Perplexity、Jasper、Gamma</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-amber-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">💻</div>
        <h3 class="text-2xl font-semibold mb-3">代码 & 数据</h3>
        <p class="text-zinc-400">Cursor、Blackbox、GitHub Copilot、Poe</p>
      </div>
      <div class="bg-zinc-900 rounded-3xl p-8 border border-zinc-800 hover:border-rose-400 transition-all group">
        <div class="text-5xl mb-6 group-hover:scale-110 transition-transform">🌐</div>
        <h3 class="text-2xl font-semibold mb-3">更多工具</h3>
        <p class="text-zinc-400">25+ 免费 AI 工具持续更新</p>
      </div>
    </div>
  </div>

</PageLayout>
